{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the Nile Key application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "userName": {
          "type": "string",
          "description": "The user's chosen user name."
        }
      },
      "required": [
        "id",
        "email",
        "userName"
      ]
    },
    "Shipment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Shipment",
      "type": "object",
      "description": "A single shipment record.",
      "properties": {
        "shipmentType": {
          "type": "string",
          "description": "The type or name of the product being shipped."
        },
        "weight": {
          "type": "number",
          "description": "The weight of the shipment in kilograms."
        },
        "containerNumber": {
          "type": "string",
          "description": "The shipping container number."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of items in the shipment."
        },
        "price": {
          "type": "number",
          "description": "The total price or value of the shipment."
        },
        "customer": {
          "type": "string",
          "description": "The name of the customer receiving the shipment."
        },
        "status": {
          "type": "string",
          "description": "The current status of the shipment.",
          "enum": ["قيد التجهيز", "في الميناء", "تم الشحن"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the shipment was created."
        }
      },
      "required": [
        "shipmentType",
        "weight",
        "containerNumber",
        "quantity",
        "price",
        "customer",
        "status",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles.  `userId` is the Firebase Auth UID.",
          "params": [
            {
              "name": "userId",
              "description": "The Firebase Auth UID of the user."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/shipments/{shipmentId}",
        "definition": {
          "entityName": "Shipment",
          "schema": {
            "$ref": "#/backend/entities/Shipment"
          },
          "description": "Stores user-saved shipment records.",
          "params": [
            {
              "name": "userId",
              "description": "The Firebase Auth UID of the owner user."
            },
            {
              "name": "shipmentId",
              "description": "Unique ID for the shipment."
            }
          ]
        }
      }
    ]
  }
}
