rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isResourceOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRequestingUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAppOwner() {
      return isSignedIn() && request.auth.token.email == 'hawadettt@gmail.com';
    }
    
    function isAppAdmin() {
      return isSignedIn() && (getRequestingUserRole() == 'admin' || isAppOwner());
    }

    function isAppStaff() {
      return isSignedIn() && (getRequestingUserRole() == 'staff' || isAppAdmin());
    }


    // -------------------------------------------------------------------------
    // User Data (/users)
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Read: The user themselves or an admin/owner can read the profile.
      allow get: if isResourceOwner(userId) || isAppOwner() || isAppAdmin();
      // List: Only admin/owner roles can list all users.
      allow list: if isAppOwner() || isAppAdmin();
      
      // Create: A user can only create their own profile. The 'id' must match their UID.
      allow create: if isResourceOwner(userId) && request.resource.data.id == userId;

      // Update: The user themselves or an admin/owner can update a profile.
      allow update: if isResourceOwner(userId) || isAppOwner() || isAppAdmin();
      
      // Delete: Only the app owner can delete a user profile.
      allow delete: if isAppOwner();

      /**
       * @description Controls access to a user's private data subcollections.
       */
      match /shipments/{shipmentId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner() || isAppAdmin() || isAppStaff();
      }
      
      match /suppliers/{supplierId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner() || isAppAdmin() || isAppStaff();
      }

      match /customers/{customerId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner() || isAppAdmin() || isAppStaff();
      }
      
      match /nfsaSuppliers/{supplierId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner() || isAppAdmin() || isAppStaff();
      }

      match /siteCategories/{categoryId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner();
        
        match /sites/{siteId} {
          allow read, write: if isResourceOwner(userId) || isAppOwner();
        }
      }
    }
    
    // -------------------------------------------------------------------------
    // Public Artifacts
    // -------------------------------------------------------------------------

    /**
     * @description Public read-only access for all public artifacts.
     */
    match /artifacts/{appId}/public/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
