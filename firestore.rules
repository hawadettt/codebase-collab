rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isResourceOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRequestingUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAppOwner() {
      // Note: This rule requires that the user's profile document exists and has a role.
      // Client-side logic must handle the initial profile creation.
      return isSignedIn() && getRequestingUserRole() == 'owner';
    }


    // -------------------------------------------------------------------------
    // User Data (/users)
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Read: The user themselves or the app owner can read the profile.
      allow get: if isResourceOwner(userId) || isAppOwner();
      allow list: if isAppOwner(); // Only the app owner can list all users.
      
      // Create: A user can only create their own profile. The 'id' must match their UID.
      allow create: if isResourceOwner(userId) && request.resource.data.id == userId;

      // Update: The user themselves or the app owner can update a profile.
      allow update: if isResourceOwner(userId) || isAppOwner();
      
      // Delete: Only the app owner can delete a user profile.
      allow delete: if isAppOwner();

      /**
       * @description Controls access to a user's private data subcollections.
       * @principle Enforces strict ownership for all documents within a user's private data tree, but allows the app owner full access.
       */
      match /shipments/{shipmentId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner();
      }
      
      match /suppliers/{supplierId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner();
      }

      match /customers/{customerId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner();
      }
      
      match /nfsaSuppliers/{supplierId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner();
      }

      match /siteCategories/{categoryId} {
        allow read, write: if isResourceOwner(userId) || isAppOwner();
        
        match /sites/{siteId} {
          allow read, write: if isResourceOwner(userId) || isAppOwner();
        }
      }
    }
    
    // -------------------------------------------------------------------------
    // Public Artifacts
    // -------------------------------------------------------------------------

    /**
     * @description Public read access for the public stations data.
     * This allows any user (authenticated or not) to get a single station document.
     */
    match /artifacts/{appId}/public/{dataType}/stations/{stationId} {
      allow get: if true;
      allow write: if false;
    }

    /**
     * @description Public list access for the public stations data.
     * This allows any user (authenticated or not) to list the entire stations collection.
     */
    match /artifacts/{appId}/public/{dataType}/stations {
      allow list: if true;
      allow write: if false;
    }
  }
}
