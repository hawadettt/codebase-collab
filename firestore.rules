rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // -------------------------------------------------------------------------
    // User Data (/users)
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Explicitly deny listing the entire users collection.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      /**
       * @description Controls access to a user's private shipments.
       * @path /users/{userId}/shipments/{shipmentId}
       * @principle Enforces strict ownership for all documents within a user's private data tree.
       */
      match /shipments/{shipmentId} {
        allow read, write: if isOwner(userId);
      }
      
      /**
       * @description Controls access to a user's private suppliers.
       * @path /users/{userId}/suppliers/{supplierId}
       */
      match /suppliers/{supplierId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Controls access to a user's private customers.
       * @path /users/{userId}/customers/{customerId}
       */
      match /customers/{customerId} {
        allow read, write: if isOwner(userId);
      }
      
      /**
       * @description Controls access to user-created NFSA suppliers.
       * @path /users/{userId}/nfsaSuppliers/{supplierId}
       */
      match /nfsaSuppliers/{supplierId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Controls access to user-created site categories.
       * @path /users/{userId}/siteCategories/{categoryId}
       */
      match /siteCategories/{categoryId} {
        allow read, write: if isOwner(userId);
        
        /**
         * @description Controls access to sites within a category.
         * @path /users/{userId}/siteCategories/{categoryId}/sites/{siteId}
         */
        match /sites/{siteId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
    
    // -------------------------------------------------------------------------
    // Public Artifacts
    // -------------------------------------------------------------------------

    /**
     * @description Public read access for application data artifacts.
     * This rule allows any user (authenticated or not) to read documents
     * from the stations subcollection.
     */
    match /artifacts/{appId}/public/{dataType} {
        // This rule allows any client to read (get and list) documents
        // from the `stations` subcollection located at:
        // /artifacts/{appId}/public/{dataType}/stations/{stationId}
        match /stations/{stationId} {
          allow read: if true;
          allow write: if false;
        }
    }
  }
}
