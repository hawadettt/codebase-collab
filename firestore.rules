rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // -------------------------------------------------------------------------
    // User Data (/users)
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Explicitly deny listing the entire users collection.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);

      /**
       * @description Controls access to a user's private shipments.
       * @path /users/{userId}/shipments/{shipmentId}
       * @principle Enforces strict ownership for all documents within a user's private data tree.
       */
      match /shipments/{shipmentId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
